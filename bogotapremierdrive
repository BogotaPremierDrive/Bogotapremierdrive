const INV=[
  {make:'BMW',model:'M2 CS',year:'2022',badge:'DESTACADO',hp:'444',acc:'4.0S',km:'18,500',price:'$285M',fin:'$3.9M',img:'https://images.unsplash.com/photo-1555215695-3004980ad54e?w=700&q=80&auto=format',certs:['RUNT Limpio','Peritaje 200P','Sin Siniestros'],forza:'⚡ PERFECT SHIFT!'},
  {make:'Porsche',model:'911 Carrera S',year:'2021',badge:'VIP',hp:'450',acc:'3.7S',km:'34,200',price:'$485M',fin:'$6.8M',img:'https://images.unsplash.com/photo-1614162692292-7ac56d7f7f1e?w=700&q=80&auto=format',certs:['RUNT Limpio','Peritaje 200P','Sin Siniestros'],forza:'🏆 ULTIMATE SPEED'},
  {make:'Mercedes',model:'AMG C63 S',year:'2023',badge:'NUEVO',hp:'503',acc:'3.4S',km:'9,800',price:'$520M',fin:'$7.2M',img:'https://images.unsplash.com/photo-1618843479313-40f8afb4b4d8?w=700&q=80&auto=format',certs:['RUNT Limpio','Peritaje 200P','Garantía Activa'],forza:'🔥 CLEAN RACING'},
];

function buildInv(){
  const g=document.getElementById('inv-grid');
  INV.forEach((v,i)=>{
    const notches=[...Array(10)].map(()=>'<div class="rpm-n"></div>').join('');
    const c=document.createElement('div');
    c.className='vc reveal';
    c.style.transitionDelay=`${i*100}ms`;
    c.innerHTML=`
      <div class="vc-img">
        <div class="forza-pop">${v.forza}</div>
        <img src="${v.img}" alt="${v.make} ${v.model}" loading="lazy">
        <div class="vc-badge">${v.badge}</div>
        <div class="vc-name"><div class="vc-make">${v.make} <span>${v.model}</span></div></div>
      </div>
      <div class="vc-body">
        <div class="vc-specs">
          <div class="vcs"><div class="vcs-v">${v.hp}</div><div class="vcs-l">HP</div></div>
          <div class="vcs"><div class="vcs-v">${v.acc}</div><div class="vcs-l">0-100</div></div>
          <div class="vcs"><div class="vcs-v">${v.km}</div><div class="vcs-l">KM</div></div>
        </div>
        <div class="rpm-wrap">
          <div class="rpm-header"><span class="rpm-lbl">RPM Score</span><span class="rpm-val">MAX OUTPUT</span></div>
          <div class="rpm-bar"><div class="rpm-fill"></div></div>
          <div class="rpm-notches">${notches}</div>
        </div>
        <div class="vc-certs">${v.certs.map(x=>`<span class="vc-cert">${x}</span>`).join('')}</div>
        <div class="vc-price">${v.price} COP</div>
        <div class="vc-fin">desde <strong>${v.fin} / mes</strong> a 72 meses · tasa preferencial</div>
        <button class="vc-cta"><span>Ver Detalles del Protocolo →</span></button>
      </div>`;
    /* Mouse tracking glow */
    c.addEventListener('mousemove',e=>{const r=c.getBoundingClientRect();c.style.setProperty('--mx',((e.clientX-r.left)/r.width*100).toFixed(1)+'%');c.style.setProperty('--my',((e.clientY-r.top)/r.height*100).toFixed(1)+'%');});
    /* Touch: activate Forza popup + RPM */
    c.addEventListener('touchstart',()=>{
      if(c._locked)return;c._locked=true;c.classList.add('tapped');
      setTimeout(()=>{c.classList.remove('tapped');c._locked=false;},2000);
    },{passive:true});
    g.appendChild(c);
  });
}

setTimeout(()=>{
  document.getElementById('sk-grid').style.display='none';
  document.getElementById('inv-grid').style.display='grid';
  buildInv();
  document.querySelectorAll('.reveal').forEach(el=>io.observe(el));
},1200);
</script>
</body>
