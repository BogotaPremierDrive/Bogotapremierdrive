<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BPD — Bogotá Premier Drive | Terminal Titan 4.0</title>
<!-- ═══ PWA ═══ -->
<link rel="manifest" id="pwa-manifest">
<meta name="theme-color" content="#E10600">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="BPD Premier">
<meta name="description" content="Bogotá Premier Drive — Terminal Titan 4.0. Vitrina premium de vehículos usados de alto rendimiento en Bogotá, Colombia.">
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Bebas+Neue&family=Barlow+Condensed:ital,wght@0,200;0,300;0,400;0,600;0,700;1,300&family=JetBrains+Mono:wght@300;400;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<style>
:root{
  --ob:#07070A;--gr:#10101A;--gr2:#18182A;--gr3:#1E1E2E;
  --gold:#C9A84C;--gold-l:#E4C060;
  --red:#E10600;--rg:rgba(225,6,0,.3);--rd:rgba(225,6,0,.1);
  --border:rgba(201,168,76,.18);--bord2:rgba(255,255,255,.06);--bord3:rgba(255,255,255,.1);
  --txt:#EDEBE2;--muted:#7A7A92;--dim:#3A3A52;--ok:#3DE87A;
  --fd:'Bebas Neue',sans-serif;
  --fo:'Orbitron',sans-serif;
  --fb:'Barlow Condensed',sans-serif;
  --fm:'JetBrains Mono',monospace;
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{background:var(--ob);color:var(--txt);font-family:var(--fb);overflow-x:hidden;cursor:none;}
body::after{content:'';position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,0,0,.02) 3px,rgba(0,0,0,.02) 4px);pointer-events:none;z-index:9990;}

/* ── CURSOR ── */
#cur,#cur-r{position:fixed;border-radius:50%;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);}
#cur{width:10px;height:10px;background:var(--gold);mix-blend-mode:screen;transition:transform .12s,background .2s;}
#cur-r{width:34px;height:34px;border:1px solid rgba(201,168,76,.45);transition:transform .38s cubic-bezier(.25,.46,.45,.94),border-color .2s,opacity .2s;}
body.hov #cur{transform:translate(-50%,-50%) scale(2.8);}
body.hov #cur-r{transform:translate(-50%,-50%) scale(1.7);opacity:.35;}
body.hov-red #cur{background:var(--red);}
body.hov-red #cur-r{border-color:rgba(225,6,0,.5);}

/* ── MOBILE OVERLAY & GAMING PAUSE DRAWER ── */
.mob-overlay{position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:1500;opacity:0;pointer-events:none;transition:opacity .4s;}
.mob-overlay.show{opacity:1;pointer-events:all;}
.mob-drawer{
  position:fixed;top:0;right:-110%;bottom:0;width:82%;max-width:340px;
  background:rgba(5,5,8,.97);backdrop-filter:blur(28px) saturate(1.5);
  border-left:2px solid var(--red);box-shadow:-20px 0 60px rgba(225,6,0,.15);
  z-index:1600;transition:right .45s cubic-bezier(.16,1,.3,1);
  padding:84px 36px 48px;display:flex;flex-direction:column;
}
.mob-drawer.open{right:0;}
.mob-close{position:absolute;top:18px;right:18px;background:none;border:1px solid rgba(255,255,255,.1);color:var(--muted);font-family:var(--fo);font-size:9px;padding:8px 12px;cursor:pointer;transition:all .2s;letter-spacing:.12em;}
.mob-close:hover{border-color:var(--red);color:var(--red);}
.mob-header{margin-bottom:32px;}
.mob-pause{font-family:var(--fo);font-size:7px;letter-spacing:.4em;color:var(--red);text-transform:uppercase;margin-bottom:4px;}
.mob-title{font-family:var(--fo);font-size:20px;font-weight:900;letter-spacing:.08em;color:var(--txt);}
.mob-nav{display:flex;flex-direction:column;flex:1;}
.mob-link{display:flex;align-items:center;gap:16px;padding:15px 0;border-bottom:1px solid var(--bord2);font-family:var(--fo);font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);text-decoration:none;transition:all .25s;}
.mob-link:hover,.mob-link:active{color:var(--red);padding-left:10px;}
.mob-i{font-size:8px;color:var(--dim);min-width:22px;}
.mob-cta-w{margin-top:24px;}
.mob-status{font-family:var(--fo);font-size:7px;letter-spacing:.18em;color:var(--dim);text-transform:uppercase;margin-top:16px;display:flex;align-items:center;gap:6px;}
.mob-pulse{width:5px;height:5px;border-radius:50%;background:var(--ok);animation:blink 1.5s step-end infinite;}

/* ── NAV ── */
nav{position:fixed;top:0;left:0;right:0;z-index:1000;height:66px;display:flex;align-items:center;justify-content:space-between;padding:0 5vw;background:rgba(7,7,10,.9);backdrop-filter:blur(20px) saturate(1.6);border-bottom:1px solid var(--border);}
.nav-logo{font-family:var(--fd);font-size:23px;letter-spacing:.14em;color:var(--gold);text-decoration:none;}
.nav-logo em{color:var(--txt);font-style:normal;}
.nav-links{display:flex;gap:2.5rem;list-style:none;}
.nav-links a{font-family:var(--fo);font-size:8px;letter-spacing:.22em;text-transform:uppercase;color:var(--muted);text-decoration:none;transition:color .2s;position:relative;}
.nav-links a::after{content:'';position:absolute;bottom:-4px;left:0;right:0;height:1px;background:var(--red);transform:scaleX(0);transition:transform .25s;transform-origin:left;}
.nav-links a:hover{color:var(--red);}
.nav-links a:hover::after{transform:scaleX(1);}
.nav-right{display:flex;align-items:center;gap:14px;}
.nav-cta{font-family:var(--fo);font-size:8px;letter-spacing:.18em;text-transform:uppercase;border:1px solid var(--gold);color:var(--gold);padding:9px 20px;text-decoration:none;transition:all .25s;position:relative;overflow:hidden;}
.nav-cta::before{content:'';position:absolute;inset:0;background:var(--gold);transform:translateX(-101%);transition:transform .28s ease;}
.nav-cta:hover{color:#000;}
.nav-cta:hover::before{transform:translateX(0);}
.nav-cta span{position:relative;z-index:1;}
.hamburger{display:none;flex-direction:column;justify-content:center;gap:5px;background:none;border:1px solid rgba(225,6,0,.35);padding:0 11px;cursor:pointer;width:44px;height:44px;transition:border-color .2s;}
.hamburger:hover{border-color:var(--red);box-shadow:0 0 14px var(--rg);}
.hamburger span{display:block;width:20px;height:1.5px;background:var(--txt);transition:all .3s;}
.hamburger.open span:nth-child(1){transform:rotate(45deg) translate(4.5px,4.5px);}
.hamburger.open span:nth-child(2){opacity:0;transform:scaleX(0);}
.hamburger.open span:nth-child(3){transform:rotate(-45deg) translate(4.5px,-4.5px);}
@media(max-width:1024px){.hamburger{display:flex;}.nav-links{display:none;}}

/* ── HERO ── */
#three-canvas{position:absolute;inset:0;z-index:1;}
.hero-bg{position:absolute;inset:0;z-index:0;background:url('https://images.unsplash.com/photo-1544636331-e26879cd4d9b?w=1800&q=80&auto=format') center/cover no-repeat;filter:brightness(.18) saturate(1.3);}
.hero{position:relative;height:100vh;min-height:680px;display:flex;align-items:flex-end;padding:0 5vw 80px;overflow:hidden;background:var(--ob);}
.hero-overlay{position:absolute;inset:0;background:linear-gradient(135deg,rgba(7,7,10,.9) 0%,rgba(7,7,10,.42) 55%,rgba(7,7,10,.82) 100%);z-index:2;}
.hero-grid{position:absolute;inset:0;z-index:2;background-image:linear-gradient(rgba(201,168,76,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(201,168,76,.025) 1px,transparent 1px);background-size:70px 70px;animation:grid-breathe 8s ease-in-out infinite;}
@keyframes grid-breathe{0%,100%{opacity:.5}50%{opacity:1}}
/* Scanlines on hero */
.hero-scan{position:absolute;inset:0;z-index:3;background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,0,0,.13) 3px,rgba(0,0,0,.13) 4px);pointer-events:none;}
/* Speed streaks */
.hs{position:absolute;top:0;bottom:0;width:1px;z-index:2;}
.hs1{right:18%;background:linear-gradient(180deg,transparent,rgba(225,6,0,.28) 40%,rgba(225,6,0,.5) 60%,transparent);}
.hs2{right:35%;background:linear-gradient(180deg,transparent,rgba(255,255,255,.04) 50%,transparent);}
.hs3{right:22%;background:linear-gradient(180deg,transparent,rgba(201,168,76,.18) 45%,rgba(201,168,76,.35) 55%,transparent);}
.hero-ghost{position:absolute;bottom:-30px;left:-10px;font-family:var(--fd);font-size:clamp(220px,28vw,420px);color:rgba(201,168,76,.025);line-height:1;pointer-events:none;user-select:none;z-index:2;letter-spacing:-.02em;}
.hero-content{position:relative;z-index:4;max-width:900px;}
.hero-tag{display:inline-flex;align-items:center;gap:10px;font-family:var(--fo);font-size:8.5px;letter-spacing:.28em;text-transform:uppercase;color:var(--gold);margin-bottom:28px;animation:fade-up 1s .1s both;}
.htdot{width:6px;height:6px;border-radius:50%;background:var(--red);box-shadow:0 0 10px var(--red);animation:blink 1.6s step-end infinite;}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0}}
@keyframes fade-up{from{opacity:0;transform:translateY(40px)}to{opacity:1;transform:translateY(0)}}

/* ────── GLITCH EFFECT (vitrina.css) ────── */
h1.ht{font-family:var(--fd);font-size:clamp(64px,9vw,136px);line-height:.9;letter-spacing:.02em;margin-bottom:30px;animation:fade-up 1.1s .2s both;}
h1.ht .g{color:var(--gold);}
h1.ht .thin{font-family:var(--fb);font-weight:200;font-size:.68em;letter-spacing:.07em;}
.glitch{position:relative;display:inline-block;}
.glitch::before,.glitch::after{content:attr(data-t);position:absolute;top:0;left:0;width:100%;height:100%;font-family:var(--fd);font-size:inherit;line-height:inherit;letter-spacing:inherit;}
.glitch::before{color:var(--red);animation:ga 5s infinite;clip-path:polygon(0 0,100% 0,100% 38%,0 38%);left:3px;text-shadow:0 0 8px var(--red);}
.glitch::after{color:var(--gold-l);animation:gb 5s 1.5s infinite;clip-path:polygon(0 62%,100% 62%,100% 100%,0 100%);left:-3px;}
@keyframes ga{0%,86%,100%{transform:none;opacity:0}88%{transform:skewX(-2deg) translateX(-8px);opacity:.9}90%{transform:skewX(1.5deg) translateX(4px);opacity:.65}92%{transform:none;opacity:0}96%{transform:skewX(-1deg) translateX(-3px);opacity:.35}}
@keyframes gb{0%,84%,100%{transform:none;opacity:0}86%{transform:skewX(3deg) translateX(6px);opacity:.75}88%{transform:skewX(-2deg) translateX(-4px);opacity:.5}90%{transform:none;opacity:0}}

/* GT RED live badge */
.hero-live{position:absolute;top:80px;right:5vw;z-index:5;display:flex;align-items:center;gap:8px;font-family:var(--fo);font-size:7.5px;letter-spacing:.28em;color:var(--red);text-transform:uppercase;animation:fade-up 1.2s .6s both;}
.live-dot{width:7px;height:7px;border-radius:50%;background:var(--red);box-shadow:0 0 12px var(--red),0 0 24px var(--rg);animation:blink 1.2s step-end infinite;}
.hero-sub{font-size:17px;font-weight:300;color:var(--muted);max-width:510px;margin-bottom:44px;line-height:1.72;animation:fade-up 1.1s .32s both;}
.hero-btns{display:flex;gap:14px;flex-wrap:wrap;animation:fade-up 1.1s .44s both;}
.hero-sc{position:absolute;bottom:30px;right:5vw;z-index:5;display:flex;flex-direction:column;align-items:center;gap:8px;}
.hero-sc-line{width:1px;height:56px;background:linear-gradient(180deg,var(--red),transparent);animation:sc-drop 2.2s ease-in-out infinite;}
@keyframes sc-drop{0%{transform:scaleY(0);transform-origin:top}50%{transform:scaleY(1);transform-origin:top}50.001%{transform:scaleY(1);transform-origin:bottom}100%{transform:scaleY(0);transform-origin:bottom}}
.hero-sc-lbl{font-family:var(--fo);font-size:7px;letter-spacing:.3em;color:var(--dim);writing-mode:vertical-rl;text-transform:uppercase;}

/* ── BUTTONS ── */
.btn-g{display:inline-flex;align-items:center;gap:10px;background:var(--gold);color:#000;padding:16px 36px;font-family:var(--fo);font-size:9px;letter-spacing:.2em;text-transform:uppercase;font-weight:700;text-decoration:none;position:relative;overflow:hidden;transition:transform .15s,box-shadow .2s;}
.btn-g:hover{transform:translateY(-2px);box-shadow:0 0 30px rgba(201,168,76,.45);}
.btn-g::after{content:'';position:absolute;inset:0;background:linear-gradient(120deg,transparent 30%,rgba(255,255,255,.28) 50%,transparent 70%);transform:translateX(-110%) skewX(-20deg);transition:transform .5s;}
.btn-g:hover::after{transform:translateX(200%) skewX(-20deg);}
.btn-r{display:inline-flex;align-items:center;gap:10px;background:var(--red);color:#fff;padding:16px 36px;font-family:var(--fo);font-size:9px;letter-spacing:.18em;text-transform:uppercase;font-weight:700;text-decoration:none;position:relative;overflow:hidden;transition:transform .15s,box-shadow .2s;}
.btn-r:hover{transform:translateY(-2px);box-shadow:0 0 32px var(--rg),0 0 64px rgba(225,6,0,.15);}
.btn-r::after{content:'';position:absolute;inset:0;background:linear-gradient(120deg,transparent 30%,rgba(255,255,255,.18) 50%,transparent 70%);transform:translateX(-110%) skewX(-20deg);transition:transform .5s;}
.btn-r:hover::after{transform:translateX(200%) skewX(-20deg);}
.btn-o{display:inline-flex;align-items:center;gap:10px;border:1px solid var(--bord3);color:var(--muted);padding:16px 36px;font-family:var(--fo);font-size:9px;letter-spacing:.2em;text-transform:uppercase;text-decoration:none;transition:all .25s;}
.btn-o:hover{border-color:var(--gold);color:var(--gold);transform:translateY(-2px);}

/* ── DIVIDER ── */
.div{height:1px;background:linear-gradient(90deg,transparent,var(--gold) 20%,var(--gold) 80%,transparent);}
.div-r{height:1px;background:linear-gradient(90deg,transparent,var(--red) 20%,var(--red) 80%,transparent);}

/* ── STATS ── */
.stats{display:grid;grid-template-columns:repeat(4,1fr);background:var(--gr);border-bottom:1px solid var(--border);}
.sc{padding:36px 28px;border-right:1px solid var(--bord2);position:relative;overflow:hidden;transition:background .3s;}
.sc:last-child{border-right:none;}
.sc:hover{background:var(--gr2);}
.sc::before{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--red),transparent);transform:scaleX(0);transform-origin:left;transition:transform .4s;}
.sc:hover::before{transform:scaleX(1);}
.sc-l{font-family:var(--fo);font-size:7px;letter-spacing:.28em;text-transform:uppercase;color:var(--dim);margin-bottom:10px;}
.sc-n{font-family:var(--fd);font-size:46px;color:var(--gold);line-height:1;}
.sc-u{font-size:11px;color:var(--muted);margin-top:5px;font-weight:300;}

/* ── SECTION HELPERS ── */
section{padding:110px 5vw;}
.ey{display:inline-flex;align-items:center;gap:12px;font-family:var(--fo);font-size:8px;letter-spacing:.28em;text-transform:uppercase;color:var(--gold);margin-bottom:16px;}
.ey::before{content:'';display:block;width:28px;height:1px;background:var(--gold);}
.ey-r{display:inline-flex;align-items:center;gap:12px;font-family:var(--fo);font-size:8px;letter-spacing:.28em;text-transform:uppercase;color:var(--red);margin-bottom:16px;}
.ey-r::before{content:'';display:block;width:28px;height:1px;background:var(--red);}
.sh{font-family:var(--fd);font-size:clamp(44px,5.8vw,78px);line-height:.95;letter-spacing:.025em;margin-bottom:18px;}
.sh .g{color:var(--gold);}
.sh .r{color:var(--red);}
.sp{font-size:16px;font-weight:300;color:var(--muted);max-width:520px;line-height:1.76;margin-bottom:48px;}
.reveal{opacity:0;transform:translateY(36px);transition:opacity .8s,transform .8s cubic-bezier(.16,1,.3,1);}
.reveal.vis{opacity:1;transform:translateY(0);}
.rl{opacity:0;transform:translateX(-40px);transition:opacity .8s,transform .8s cubic-bezier(.16,1,.3,1);}
.rl.vis{opacity:1;transform:translateX(0);}
.rr{opacity:0;transform:translateX(40px);transition:opacity .8s,transform .8s cubic-bezier(.16,1,.3,1);}
.rr.vis{opacity:1;transform:translateX(0);}

/* ── GALLERY ── */
.gallery-header{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:40px;}
.gallery-count{font-family:var(--fo);font-size:8px;letter-spacing:.22em;color:var(--dim);text-transform:uppercase;}
.gallery-masonry{display:grid;grid-template-columns:repeat(12,1fr);gap:3px;}
.gp{overflow:hidden;position:relative;cursor:pointer;background:var(--gr);}
.gp img{width:100%;height:100%;object-fit:cover;transition:transform .6s cubic-bezier(.16,1,.3,1),filter .4s;}
.gp:hover img{transform:scale(1.07);filter:brightness(1.12);}
.gp-grad{position:absolute;inset:0;background:linear-gradient(180deg,transparent 60%,rgba(7,7,10,.92) 100%);opacity:0;transition:opacity .35s;z-index:1;}
.gp:hover .gp-grad{opacity:1;}
.gp-border{position:absolute;inset:0;border:2px solid var(--red);opacity:0;transition:opacity .3s,box-shadow .3s;z-index:3;pointer-events:none;}
.gp:hover .gp-border{opacity:.65;box-shadow:inset 0 0 20px rgba(225,6,0,.15);}
.gp-label{position:absolute;bottom:14px;left:16px;z-index:2;opacity:0;transform:translateY(8px);transition:all .3s;}
.gp:hover .gp-label{opacity:1;transform:translateY(0);}
.gp-label .make{font-family:var(--fd);font-size:20px;color:var(--txt);letter-spacing:.06em;}
.gp-label .badge{font-family:var(--fo);font-size:7px;letter-spacing:.18em;color:var(--red);text-transform:uppercase;margin-bottom:3px;}
.gp.l1{grid-column:1/6;grid-row:1/3;height:420px;}
.gp.l2{grid-column:6/10;grid-row:1/2;height:205px;}
.gp.l3{grid-column:10/13;grid-row:1/2;height:205px;}
.gp.l4{grid-column:6/9;grid-row:2/3;height:205px;}
.gp.l5{grid-column:9/13;grid-row:2/3;height:205px;}
.gp.l6{grid-column:1/4;grid-row:3/4;height:240px;}
.gp.l7{grid-column:4/8;grid-row:3/4;height:240px;}
.gp.l8{grid-column:8/13;grid-row:3/4;height:240px;}

/* ── RACING FILM SHOWCASE ── */
.films-section{background:var(--gr);padding:90px 5vw;}
.films-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:3px;margin-top:52px;}
.film-card{position:relative;height:260px;overflow:hidden;background:var(--gr2);cursor:pointer;}
.film-img{width:100%;height:100%;object-fit:cover;transition:transform .6s cubic-bezier(.16,1,.3,1),filter .4s;filter:brightness(.65) saturate(1.1);}
.film-card:hover .film-img{transform:scale(1.06);filter:brightness(.85) saturate(1.3);}
.film-overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(7,7,10,.3) 0%,transparent 40%,rgba(7,7,10,.92) 100%);pointer-events:none;z-index:2;}
.film-scan{position:absolute;inset:0;z-index:3;background:repeating-linear-gradient(0deg,transparent,transparent 4px,rgba(0,0,0,.1) 4px,rgba(0,0,0,.1) 5px);pointer-events:none;}
.film-meta{position:absolute;bottom:18px;left:20px;z-index:4;}
.film-brand{font-family:var(--fd);font-size:24px;letter-spacing:.08em;color:var(--txt);}
.film-tag{font-family:var(--fo);font-size:7px;letter-spacing:.22em;text-transform:uppercase;color:var(--red);margin-top:3px;}
.film-play{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%) scale(.85);width:56px;height:56px;border:2px solid rgba(255,255,255,.35);border-radius:50%;display:flex;align-items:center;justify-content:center;z-index:4;transition:all .3s;opacity:.7;}
.film-card:hover .film-play{transform:translate(-50%,-50%) scale(1.05);border-color:var(--red);box-shadow:0 0 28px var(--rg);opacity:1;}
.film-play::after{content:'';border-top:9px solid transparent;border-bottom:9px solid transparent;border-left:16px solid rgba(255,255,255,.9);margin-left:4px;}
.film-card:hover .film-play::after{border-left-color:#fff;}
.film-neon{position:absolute;inset:0;border:2px solid var(--red);opacity:0;z-index:5;pointer-events:none;transition:opacity .3s;box-shadow:inset 0 0 30px rgba(225,6,0,.12);}
.film-card:hover .film-neon{opacity:.7;}
/* Runtime badge */
.film-time{position:absolute;top:14px;right:14px;font-family:var(--fo);font-size:8px;letter-spacing:.12em;background:rgba(5,5,8,.85);color:var(--txt);padding:4px 9px;z-index:4;border:1px solid rgba(255,255,255,.08);}

/* ── INVENTORY ── */
.inv-section{background:var(--ob);}
.inv-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:3px;background:var(--bord2);margin-top:56px;}
.vc{background:var(--gr2);position:relative;overflow:hidden;cursor:pointer;transition:transform .45s cubic-bezier(.16,1,.3,1);}
.vc:hover{transform:scale(1.013);z-index:10;}
.vc::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at var(--mx,50%) var(--my,50%),rgba(225,6,0,.07) 0%,transparent 65%);opacity:0;transition:opacity .4s;z-index:1;pointer-events:none;}
.vc:hover::before{opacity:1;}

/* FORZA HORIZON POPUP (vitrina.js) */
.forza-pop{position:absolute;top:12px;left:50%;transform:translateX(-50%) scale(0) translateY(-6px);font-family:var(--fo);font-size:9px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;background:rgba(5,5,8,.96);border:1px solid var(--red);color:var(--red);padding:8px 18px;white-space:nowrap;z-index:20;box-shadow:0 0 28px var(--rg),0 0 60px rgba(225,6,0,.12);transition:transform .38s cubic-bezier(.34,1.56,.64,1),opacity .3s;opacity:0;pointer-events:none;}
.vc:hover .forza-pop,.vc.tapped .forza-pop{transform:translateX(-50%) scale(1) translateY(0);opacity:1;}

.vc-img{position:relative;overflow:hidden;height:250px;}
.vc-img img{width:100%;height:100%;object-fit:cover;transition:transform .6s cubic-bezier(.16,1,.3,1);}
.vc:hover .vc-img img,.vc.tapped .vc-img img{transform:scale(1.06);}
.vc-img::after{content:'';position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(16,16,26,.92) 100%);}
.vc-img::before{content:'';position:absolute;inset:0;background:linear-gradient(90deg,transparent,rgba(225,6,0,.09),transparent);z-index:2;opacity:0;pointer-events:none;}
.vc:hover .vc-img::before,.vc.tapped .vc-img::before{animation:mb .7s ease-out forwards;}
@keyframes mb{0%{opacity:0;transform:translateX(-100%) skewX(-14deg)}50%{opacity:1}100%{opacity:0;transform:translateX(220%) skewX(-14deg)}}

.vc-badge{position:absolute;top:14px;right:14px;font-family:var(--fo);font-size:7px;letter-spacing:.16em;text-transform:uppercase;background:var(--red);color:#fff;padding:5px 10px;font-weight:700;z-index:3;}
.vc-name{position:absolute;bottom:18px;left:20px;z-index:3;}
.vc-make{font-family:var(--fd);font-size:26px;letter-spacing:.06em;color:var(--txt);}
.vc-make span{color:var(--gold);}
.vc-body{padding:22px 22px 26px;position:relative;z-index:2;}
.vc-specs{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--bord2);margin-bottom:14px;}
.vcs{background:var(--gr3);padding:13px 10px;text-align:center;}
.vcs-v{font-family:var(--fd);font-size:22px;color:var(--gold);}
.vcs-l{font-family:var(--fo);font-size:6.5px;letter-spacing:.18em;text-transform:uppercase;color:var(--dim);margin-top:2px;}

/* RPM BAR (Gran Turismo telemetry) */
.rpm-wrap{margin-bottom:15px;}
.rpm-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:5px;}
.rpm-lbl{font-family:var(--fo);font-size:6.5px;letter-spacing:.22em;color:var(--dim);text-transform:uppercase;}
.rpm-val{font-family:var(--fo);font-size:6.5px;letter-spacing:.18em;color:var(--red);text-transform:uppercase;transition:opacity .3s;}
.rpm-bar{height:3px;background:rgba(225,6,0,.08);overflow:hidden;position:relative;}
.rpm-fill{height:100%;width:0%;background:linear-gradient(90deg,var(--red) 0%,#ff4040 80%,#ffaaaa 100%);box-shadow:0 0 10px var(--red);transition:width 1.8s cubic-bezier(.16,1,.3,1);}
.vc:hover .rpm-fill,.vc.tapped .rpm-fill{width:100%;}
.rpm-notches{display:flex;justify-content:space-between;margin-top:4px;}
.rpm-n{width:1px;height:5px;background:var(--bord2);}
.rpm-n:nth-child(-n+4){background:rgba(225,6,0,.45);}

.vc-certs{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:14px;}
.vc-cert{font-family:var(--fo);font-size:6.5px;letter-spacing:.1em;text-transform:uppercase;border:1px solid rgba(201,168,76,.22);color:rgba(201,168,76,.65);padding:4px 8px;}
.vc-price{font-family:var(--fd);font-size:38px;color:var(--txt);letter-spacing:.04em;}
.vc-fin{font-size:13px;font-weight:300;color:var(--muted);margin-bottom:18px;}
.vc-fin strong{color:var(--gold);font-weight:600;}
.vc-cta{width:100%;padding:13px;background:transparent;border:1px solid rgba(225,6,0,.3);color:var(--muted);font-family:var(--fo);font-size:8px;letter-spacing:.2em;text-transform:uppercase;cursor:pointer;transition:all .25s;position:relative;overflow:hidden;}
.vc-cta::before{content:'';position:absolute;inset:0;background:var(--red);transform:scaleX(0);transform-origin:left;transition:transform .3s ease;}
.vc-cta:hover{color:#fff;border-color:var(--red);box-shadow:0 0 20px var(--rg);}
.vc-cta:hover::before{transform:scaleX(1);}
.vc-cta span{position:relative;z-index:1;}

/* Skeleton */
.sk-card{background:var(--gr2);}
.sk-img{height:250px;position:relative;overflow:hidden;}
.sk{background:var(--gr3);border-radius:1px;position:relative;overflow:hidden;}
.sk::after{content:'';position:absolute;inset:0;background:linear-gradient(90deg,transparent,rgba(255,255,255,.045),transparent);animation:sh 1.7s infinite;}
@keyframes sh{0%{transform:translateX(-100%)}100%{transform:translateX(100%)}}
.sk-h32{height:32px;margin-bottom:12px;}.sk-h16{height:16px;margin-bottom:8px;}.sk-h12{height:12px;width:65%;margin-bottom:8px;}
.sk-gr{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;margin-bottom:16px;}
.sk-g{background:var(--gr3);height:52px;position:relative;overflow:hidden;}
.sk-g::after{content:'';position:absolute;inset:0;background:linear-gradient(90deg,transparent,rgba(255,255,255,.04),transparent);animation:sh 1.7s .35s infinite;}

/* ── TITAN SEAL (Gran Turismo HUD) ── */
.seal-section{background:var(--gr);padding:100px 5vw;}
.seal-layout{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;}
.seal-ring-wrap{display:flex;align-items:center;justify-content:center;position:relative;height:380px;}
.seal-r{position:absolute;border-radius:50%;}
.seal-r1{width:290px;height:290px;border:2px solid rgba(225,6,0,.3);animation:rs 22s linear infinite;}
.seal-r2{width:224px;height:224px;border:1px solid rgba(201,168,76,.2);animation:rs 13s linear infinite reverse;}
.seal-r3{width:168px;height:168px;border:1px solid rgba(255,255,255,.05);animation:rs 9s linear infinite;}
.seal-r4{width:320px;height:320px;border:1px dashed rgba(225,6,0,.1);animation:rs 40s linear infinite reverse;}
@keyframes rs{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
.seal-dot{position:absolute;width:7px;height:7px;border-radius:50%;background:var(--red);box-shadow:0 0 12px var(--red);}
.sd-t{top:-4px;left:50%;transform:translateX(-50%);}
.sd-b{bottom:-4px;left:50%;transform:translateX(-50%);}
.sd-l{left:-4px;top:50%;transform:translateY(-50%);}
.sd-r{right:-4px;top:50%;transform:translateY(-50%);}
.seal-inner{position:absolute;text-align:center;z-index:5;}
.seal-badge{font-family:var(--fo);font-size:7px;letter-spacing:.3em;color:var(--red);text-transform:uppercase;margin-bottom:10px;}
.seal-score{font-family:var(--fd);font-size:80px;color:var(--txt);line-height:1;}
.seal-unit{font-family:var(--fo);font-size:7.5px;letter-spacing:.22em;color:var(--dim);text-transform:uppercase;margin-top:4px;}
.seal-label{font-family:var(--fd);font-size:26px;color:var(--gold);margin-top:6px;}
.seal-data{display:flex;flex-direction:column;gap:0;}
.sd-row{display:flex;justify-content:space-between;align-items:center;padding:14px 0;border-bottom:1px solid var(--bord2);}
.sd-k{font-family:var(--fo);font-size:7.5px;letter-spacing:.2em;text-transform:uppercase;color:var(--dim);}
.sd-v{font-family:var(--fm);font-size:14px;font-weight:700;color:var(--gold);}
.sd-v.r{color:var(--red);}
.sd-v.ok{color:var(--ok);}
.sd-bar-wrap{display:flex;align-items:center;gap:8px;}
.sd-bar{width:70px;height:2px;background:rgba(255,255,255,.05);}
.sd-fill{height:100%;background:var(--gold);box-shadow:0 0 6px var(--gold);transition:width 1.5s cubic-bezier(.16,1,.3,1);}
.sd-fill.r{background:var(--red);box-shadow:0 0 6px var(--red);}

/* ── 3D SCANNER ── */
.scanner-section{background:var(--ob);}
.scanner-layout{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;}
.scan-steps{display:flex;flex-direction:column;}
.sstep{display:flex;gap:22px;padding:26px 0;border-bottom:1px solid var(--bord2);transition:all .2s;}
.sstep:hover .ss-n{color:var(--red);}
.ss-n{font-family:var(--fo);font-size:26px;font-weight:900;color:var(--dim);line-height:1;min-width:38px;transition:color .2s;}
.ss-c h4{font-family:var(--fo);font-size:9px;letter-spacing:.18em;text-transform:uppercase;color:var(--txt);margin-bottom:5px;font-weight:700;}
.ss-c p{font-size:14px;color:var(--muted);font-weight:300;}
.scan-3d-wrap{position:relative;height:420px;display:flex;align-items:center;justify-content:center;}
#scan-canvas{width:100%;height:100%;border:1px solid rgba(225,6,0,.2);background:#05050A;}
.scan-overlay{position:absolute;bottom:0;left:0;right:0;padding:18px 22px;background:rgba(5,5,8,.92);border-top:1px solid rgba(225,6,0,.15);}
.t-row{display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid rgba(255,255,255,.04);font-family:var(--fo);font-size:9px;}
.t-k{color:var(--dim);}
.t-v{color:var(--gold);font-weight:700;}
.t-v.ok{color:var(--ok);}
.t-pb{height:2px;background:rgba(255,255,255,.04);overflow:hidden;margin-top:12px;}
.t-pf{height:100%;background:var(--red);box-shadow:0 0 6px var(--red);animation:pa 2.5s ease-in-out infinite;}
@keyframes pa{0%{width:0%}75%{width:100%}100%{width:100%;opacity:0}}

/* ── MARKET ── */
.market-section{background:var(--gr);}
.mkt-n{font-family:var(--fd);font-size:clamp(100px,17vw,200px);color:var(--gold);line-height:.85;letter-spacing:.04em;position:relative;}
.mkt-n::after{content:attr(data-u);position:absolute;bottom:-6px;left:4px;font-family:var(--fo);font-size:7.5px;letter-spacing:.28em;color:var(--dim);text-transform:uppercase;}
.ins-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:3px;background:var(--bord2);margin-top:60px;}
.ins{background:var(--ob);padding:36px 28px;}
.ins-n{font-family:var(--fd);font-size:50px;color:var(--gold);margin-bottom:10px;}
.ins-t{font-family:var(--fo);font-size:9px;letter-spacing:.14em;text-transform:uppercase;color:var(--txt);font-weight:700;margin-bottom:10px;}
.ins-p{font-size:14px;color:var(--muted);font-weight:300;line-height:1.72;}

/* ── COMPARE ── */
.cmp-section{background:var(--ob);}
.cmp-t{width:100%;border-collapse:collapse;margin-top:48px;}
.cmp-t th{padding:13px 22px;text-align:left;font-family:var(--fo);font-size:7.5px;letter-spacing:.25em;text-transform:uppercase;color:var(--dim);border-bottom:1px solid var(--bord2);}
.cmp-t th.g{color:var(--gold);}
.cmp-t td{padding:15px 22px;border-bottom:1px solid var(--bord2);font-size:14px;font-weight:300;color:var(--muted);transition:background .2s;}
.cmp-t tr:hover td{background:rgba(255,255,255,.014);}
.cmp-t td.cat{font-family:var(--fo);font-size:7.5px;letter-spacing:.2em;text-transform:uppercase;color:var(--dim);}
.cmp-t td.bpd{color:var(--gold);font-weight:600;font-size:13px;}

/* ── CTA ── */
.cta-sec{background:var(--gr);text-align:center;padding:130px 5vw;position:relative;overflow:hidden;}
.cta-sec::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 900px 450px at 50% 50%,rgba(225,6,0,.07) 0%,transparent 70%);pointer-events:none;}
.cta-sec::after{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 600px 300px at 50% 50%,rgba(201,168,76,.055) 0%,transparent 70%);pointer-events:none;}
.cta-sec .sh{font-size:clamp(52px,9vw,108px);max-width:800px;margin:0 auto 16px;}
.cta-sec .sp{margin:0 auto 50px;text-align:center;}
.cta-btns{display:flex;justify-content:center;gap:16px;flex-wrap:wrap;}

/* ── TICKER (GT Red) ── */
.ticker{background:var(--red);overflow:hidden;white-space:nowrap;padding:13px 0;}
.tk-track{display:inline-flex;animation:tk 18s linear infinite;}
.tk-i{font-family:var(--fo);font-size:10px;letter-spacing:.2em;color:#fff;padding:0 28px;font-weight:700;}
.tk-s{color:rgba(255,255,255,.3);padding:0 4px;}
@keyframes tk{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

/* ── FOOTER ── */
footer{background:#050507;border-top:1px solid var(--border);padding:68px 5vw 32px;}
.ft{display:grid;grid-template-columns:1fr 1fr;gap:80px;padding-bottom:48px;border-bottom:1px solid var(--bord2);margin-bottom:32px;}
.fl{font-family:var(--fd);font-size:32px;letter-spacing:.1em;color:var(--gold);margin-bottom:10px;}
.fl em{color:var(--txt);font-style:normal;}
.ftag{font-family:var(--fo);font-size:7px;letter-spacing:.2em;color:var(--dim);text-transform:uppercase;}
.fsoc{display:flex;gap:8px;flex-wrap:wrap;margin-top:20px;}
.fs{font-family:var(--fo);font-size:7px;letter-spacing:.14em;color:var(--dim);text-transform:uppercase;text-decoration:none;border:1px solid var(--bord2);padding:6px 12px;transition:all .2s;}
.fs:hover{color:var(--red);border-color:rgba(225,6,0,.4);}
.fa h4{font-family:var(--fo);font-size:7.5px;letter-spacing:.25em;color:var(--dim);text-transform:uppercase;margin-bottom:12px;}
.fa p{font-size:14px;color:var(--muted);font-weight:300;line-height:1.8;}
.fb2{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;}
.fc{font-family:var(--fo);font-size:7px;letter-spacing:.12em;color:var(--dim);text-transform:uppercase;}

/* ── RESPONSIVE ── */
@media(max-width:900px){
  .stats{grid-template-columns:repeat(2,1fr);}
  .scanner-layout,.seal-layout{grid-template-columns:1fr;}
  .seal-ring-wrap{height:280px;}
  .ins-grid{grid-template-columns:1fr;}
  .films-grid{grid-template-columns:1fr;}
  .film-card{height:220px;}
  .gallery-masonry{grid-template-columns:repeat(2,1fr);}
  .gp.l1,.gp.l2,.gp.l3,.gp.l4,.gp.l5,.gp.l6,.gp.l7,.gp.l8{grid-column:auto;grid-row:auto;height:200px;}
  .ft{grid-template-columns:1fr;gap:40px;}
  body{cursor:auto;}
  #cur,#cur-r{display:none;}
}
@media(max-width:600px){
  .stats{grid-template-columns:1fr;}
  .gallery-masonry{grid-template-columns:1fr;}
}
</style>
</head>
