/* ─── THREE.JS HERO ─── */
(function(){
  const canvas=document.getElementById('three-canvas');
  const renderer=new THREE.WebGLRenderer({canvas,antialias:true,alpha:true});
  renderer.setPixelRatio(Math.min(window.devicePixelRatio,2));
  renderer.setClearColor(0x000000,0);
  const scene=new THREE.Scene();
  const camera=new THREE.PerspectiveCamera(60,2,0.1,100);
  camera.position.set(0,0,4);
  function resize(){
    const w=canvas.parentElement.clientWidth,h=canvas.parentElement.clientHeight;
    renderer.setSize(w,h);camera.aspect=w/h;camera.updateProjectionMatrix();
  }
  resize();window.addEventListener('resize',resize);
  /* Particles */
  const pos=[];
  for(let i=0;i<2400;i++)pos.push((Math.random()-.5)*14,(Math.random()-.5)*10,(Math.random()-.5)*8);
  const geo=new THREE.BufferGeometry();
  geo.setAttribute('position',new THREE.Float32BufferAttribute(pos,3));
  scene.add(new THREE.Points(geo,new THREE.PointsMaterial({color:0xC9A84C,size:.026,transparent:true,opacity:.5,sizeAttenuation:true})));
  /* GT Red accent particles */
  const rpos=[];
  for(let i=0;i<600;i++)rpos.push((Math.random()-.5)*12,(Math.random()-.5)*8,(Math.random()-.5)*6);
  const rgeo=new THREE.BufferGeometry();
  rgeo.setAttribute('position',new THREE.Float32BufferAttribute(rpos,3));
  scene.add(new THREE.Points(rgeo,new THREE.PointsMaterial({color:0xE10600,size:.018,transparent:true,opacity:.35,sizeAttenuation:true})));
  /* Grid plane */
  const grid=new THREE.Mesh(new THREE.PlaneGeometry(20,20,24,24),new THREE.MeshBasicMaterial({color:0xC9A84C,wireframe:true,transparent:true,opacity:.035}));
  grid.rotation.x=-Math.PI/2.8;grid.position.y=-3;scene.add(grid);
  /* Tori */
  const t1=new THREE.Mesh(new THREE.TorusGeometry(1.2,.022,16,80),new THREE.MeshBasicMaterial({color:0xC9A84C,transparent:true,opacity:.16}));
  t1.position.set(2.5,0,0);scene.add(t1);
  const t2=new THREE.Mesh(new THREE.TorusGeometry(.7,.014,12,60),new THREE.MeshBasicMaterial({color:0xE10600,transparent:true,opacity:.12}));
  t2.position.set(-2.8,.5,-.5);scene.add(t2);
  let mx=0,my=0;
  document.addEventListener('mousemove',e=>{mx=(e.clientX/window.innerWidth-.5)*2;my=(e.clientY/window.innerHeight-.5)*2;});
  let t=0;
  (function loop(){requestAnimationFrame(loop);t+=.008;
    scene.children[0].rotation.y=t*.06;scene.children[0].rotation.x=t*.025;
    scene.children[1].rotation.y=-t*.05;scene.children[1].rotation.z=t*.03;
    t1.rotation.x=t*.4;t1.rotation.z=t*.15;
    t2.rotation.y=t*.35;t2.rotation.x=t*.22;
    camera.position.x+=(mx*.8-camera.position.x)*.04;
    camera.position.y+=(-my*.5-camera.position.y)*.04;
    camera.lookAt(scene.position);renderer.render(scene,camera);
  })();
})();

/* ─── SCANNER 3D ─── */
(function(){
  const canvas=document.getElementById('scan-canvas');
  const pw=canvas.parentElement.clientWidth,ph=Math.max(canvas.parentElement.clientHeight-120,260);
  const renderer=new THREE.WebGLRenderer({canvas,antialias:true,alpha:true});
  renderer.setPixelRatio(Math.min(window.devicePixelRatio,2));
  renderer.setSize(pw,ph);renderer.setClearColor(0x05050A,1);
  const scene=new THREE.Scene();
  const camera=new THREE.PerspectiveCamera(50,pw/ph,.1,100);
  camera.position.set(0,0,4.5);
  const cube=new THREE.Mesh(new THREE.BoxGeometry(2,2,2),new THREE.MeshBasicMaterial({color:0xC9A84C,wireframe:true,transparent:true,opacity:.32}));scene.add(cube);
  const cube2=new THREE.Mesh(new THREE.BoxGeometry(1.2,1.2,1.2),new THREE.MeshBasicMaterial({color:0xE10600,wireframe:true,transparent:true,opacity:.2}));scene.add(cube2);
  const pp=[];for(let i=0;i<400;i++)pp.push((Math.random()-.5)*6,(Math.random()-.5)*6,(Math.random()-.5)*6);
  const pg=new THREE.BufferGeometry();pg.setAttribute('position',new THREE.Float32BufferAttribute(pp,3));
  scene.add(new THREE.Points(pg,new THREE.PointsMaterial({color:0xC9A84C,size:.022,transparent:true,opacity:.4})));
  const ring=new THREE.Mesh(new THREE.RingGeometry(1.5,1.52,64),new THREE.MeshBasicMaterial({color:0xE10600,transparent:true,opacity:.55,side:THREE.DoubleSide}));scene.add(ring);
  let t=0;
  (function loop(){requestAnimationFrame(loop);t+=.012;
    cube.rotation.x=t*.4;cube.rotation.y=t*.6;
    cube2.rotation.x=-t*.5;cube2.rotation.y=-t*.3;
    ring.rotation.x=Math.sin(t*.5)*Math.PI;ring.rotation.y=t*.3;
    ring.scale.setScalar(.8+Math.sin(t*2)*.15);
    renderer.render(scene,camera);
  })();
})();

